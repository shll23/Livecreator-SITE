# ============================================
# Database
# ============================================
POSTGRES_USER=lc
POSTGRES_PASSWORD=lc
POSTGRES_DB=lc
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================
# Redis
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# Backend
# ============================================
APP_ENV=development
APP_PORT=8080
APP_LOG_LEVEL=debug

# CHANGE THESE IN PRODUCTION!
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars-long
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-chars-long
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# CORS — Origins die das Backend erreichen dürfen
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# Frontend Creator
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8080

# ============================================
# Frontend Customer
# ============================================
# (gleicher API_URL, aber unterschiedlicher Container)

# ============================================
# Payment (später)
# ============================================
PAYMENT_PROVIDER=mock
# PAYMENT_PROVIDER=ccbill
# CCBILL_ACCOUNT_NUM=
# CCBILL_SUB_ACCOUNT_NUM=
# CCBILL_FLEXFORM_ID=
# CCBILL_SALT=
